{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "target": "ESNext",
        "module": "ESNext",
        "types": ["vite/client"],
        "skipLibCheck": true,
        "allowJs": true,
        "esModuleInterop": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "noEmit": true,

        /* Linting */
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "jsx": "react-jsx",

        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts", "src/main.tsx"]
}
